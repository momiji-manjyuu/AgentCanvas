{
  "name": "agent-canvas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "description": "Local-first design canvas for developers and AI coding agents.",
  "scripts": {
    "dev": "pnpm --filter @agent-canvas/core build && pnpm --filter @agent-canvas/desktop dev",
    "build": "pnpm -r --sort build",
    "typecheck": "pnpm --filter @agent-canvas/core build && pnpm -r --sort --if-present typecheck",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "test": "pnpm -r --sort --if-present test",
    "mcp": "pnpm --filter @agent-canvas/mcp-server start --",
    "package": "pnpm --filter @agent-canvas/desktop package",
    "package:dir": "pnpm --filter @agent-canvas/desktop package:dir",
    "sample": "pnpm --filter @agent-canvas/core sample"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.6",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
